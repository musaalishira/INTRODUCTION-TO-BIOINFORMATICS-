#!/bin/bash

# 1. header
echo "Name,Email,GitHub_Username,Area_of_Interest" > results.csv

# 2. musa script
bash Musa.sh | paste -sd "," - >> results.csv

# 3. hassan script
Rscript Hassan.R | paste -sd "," - >> results.csv

# 4. fadila script
perl Fadila.pl | paste -sd "," - >> results.csv

# 5. istifanus script
g++ Istifanus.cpp -o istifanus_exec
./istifanus_exec | paste -sd "," - >> results.csv
rm istifanus_exec

# 6. maryam script
javac Maryam.java
java maryam | paste -sd "," - >> results.csv

echo "done. files saved to results.csv"
